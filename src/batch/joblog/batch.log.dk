#include "dkli.dkh"
#!
module "list.dk"
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "uielements.v12.dkl"

    do @context.begin(@crud_context)

    ref entity = ifnull(@("&./entity"),record.create())
    ref jobs = ifnull(@("&./jobs"),list.create())
    ref titles = ifnull(@("&./titles"),record.create())

	@_entities_type = @("$parameters/_entities_type")
    @_entity_id = @("$parameters/_entity_id")
    
    table_id = "tbl_jobs"
    urlexit = "/!/batch/jobsgroup/"
    
    codeblock ""
    {
        urlexit = urlexit + @@(list.obj(jobs,0),"$jp_ref") + "/"
        exception{ do pop_exception() }
    }

    tbtn_style = "cursor:pointer; text-decoration:none; border:none; outline:none; padding: 0px 8px; background-color:#F5F5F5; color:#000000;"
    new table_definition
    {
        @"datatable*": jobs
        member @"columns"
        {
            member @"sys_guid" { @"caption":"ID" }
            member @"usuario" { @"caption":"Usuario" }
			member @"start"
            {
                @"caption":"Inicio"
                @"align":"center"
            }
            member @"end"
            {
                @"caption":"Fin"
                @"align":"center"
            }
            member @"cstatus"
            {
                @"caption":"Estado"
                @"align":"center"
            }
            member @"_actions" 
            { 
                @"caption":"Acciones" 
                @"template":ftext('
                    <div style="display:flex;gap:8px;justify-content:center;width:100%;" class="no-print">
                        <a href="/!/batch/joblog/${DataRow.sys_pk}/logs/" style="#<tbtn_style>">Ver logs</a>
                    </div>')
                @"no-print":@true
            }
        }
        @"table_footer": "Mostrando los primeros # registros"
    }

    new nav_config
    {
        @"title": @_entity_id + " [Ejecuciones]"
        @"urlexit": "javascript:window.history.back();" //urlexit
        @"print_mode": 0 // 0-window.print() | 1-v12PrintHTML()
    }
    // Encapsula a la vista en su totalidad, todo lo que hay antes o después no se considera 
    #$
    div(class="container-fluid" id="view")
    {
        // Filtros y acciones
        section(id="top_area")
        {
            #!
            do uie.printV12FormBar(nav_config)
            #$

            // form(class="mb-1" action="./" method="GET" id="form-filter")
            // {
            //     "filter-text"(
            //         "id"="fil_text"
            //         "text-field"="fil_text"
            //         "placeholder"="Buscar ..."
            //         "form"="#form-filter"
            //         "value"="#<@('$parameters/fil_text')>"
            //         "auto-submit"="true"
            //         "class"="w-100"
            //     ){$""}
            // }
        }
        // Contenido principal
        section(id="work_area")
        {
            div(class="show-on-print")
            {
                p(class="text-center my-0"){$"#<@@(titles,'$title')>"}
                p(class="text-center my-0"){$"#<@@(titles,'$subtitle')>"}
                p(class="text-center my-0"){$"#<@@(titles,'$subtitle_2')>"}

                div(class="row")
                {
                    div(class="col-3 text-start")
                    {
                        small(class="d-block"){ $"#<cut(@('$http/session/user/name'),25)>" }
                        small(class="d-block"){ $"#<date_str(now(),'dd/MMM/yyyy')>" }
                    }
                    div(class="col-6 text-center")
                    {
                        h4(class=""){$"#<@_entity_id> [Ejecuciones]"}
                    }
                    div(class="col-3 text-end")
                    {
                        small(class="d-block" id="lbl_filter_1"){$""}
                        small(class="d-block" id="lbl_filter_2"){$""}
                        small(class="d-block" id="lbl_filter_3"){$""}
                    }
                }
            }

            #!
            do uie.dbeditable(table_definition,table_id)
            #$

            div(class="show-on-print"){p(class="fixed-bottom text-center my-1"){$"#<@@(titles,'$footer')>"}}
        }
        // Resúmenes y datos al pie
        section(id="bottom_area"){$""}

        //////////////////////////////////////////////////////////////////
        div(id="_custom_area")
        {
            // script(src=""){$""}
            script(type="text/javascript")
            {$'
                document.addEventListener("DOMContentLoaded", () => {
                    // Script injection
                    #<@@(@crud_context,"script")>
                });
            '}
        }
    }
    #!

    do @context.end()
}