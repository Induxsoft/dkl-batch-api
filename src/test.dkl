#include "dkli.dkh"
#!
program
{
	#include "functions.dkh"
	#include "serialize.dkh"
	#include "webcl.dkh"

	new header
	{
		@"Content-Type": "application/json;charset=utf-8"
		@"Authorization": "Basic "+to.base64("serie.e:12345")
	}
	//crear trabajo
	new data
	{
		@"program": "serie.dkl"
	    @"timeout": ""
	    @"progress_type": ""
	    @"steps": ""
	    @"owner":""
	    @"params": ""
	}
	// //update estado y progreso
	// new data
	// {
	// 	@"note":"mi nota"
	//     @"new_status": "1"
	//     @"progress": "3"
	//     @"sender":""
	//     @"result":" Objeto con el resultado del trabajo si new_status es un estado final"
	// }


	res =http.request("http://192.168.0.185/jobs/","POST",header,to.json(data))

	do print(res)

	exception
	{
		do print(last_error())
	}
}